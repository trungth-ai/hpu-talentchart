# TalentChart — PRODUCTION environment template
# Copy thành .env.production trên server và điền GIÁ TRỊ THẬT.
# ⚠️ KHÔNG secret nào được để rỗng/default khi go-live (checklist HUONG-DAN §9)

APP_ENV=production

# ─── Domain ───
APP_DOMAIN=hr.hpu.edu.vn            # domain chính: admin UI + API (/api/*)
CAREER_DOMAIN=hpu.hr.hpu.edu.vn     # career page công khai của tenant hpu (cần DNS record)

# ─── Database / Cache ───
DB_PASSWORD=                    # random dài >= 24 ký tự
REDIS_PASSWORD=                 # random dài >= 24 ký tự

# ─── Bảo mật ───
JWT_SECRET=                     # random >= 64 ký tự: openssl rand -hex 32
GOOGLE_CLIENT_ID=               # OAuth Client từ Google Cloud Console (ADR-004)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=   # giống GOOGLE_CLIENT_ID (frontend build arg)

# ─── AI ───
ANTHROPIC_API_KEY=              # narrative polish (ADR-005) — có thể bỏ trống, dùng template

# ─── Rate limit (production dùng Redis, không dùng memory) ───
RATE_LIMIT_STORAGE_URI=redis://:${REDIS_PASSWORD}@redis:6379/1

# ─── Storage / Email / Khác ───
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
CLOUDFLARE_API_TOKEN=           # wildcard SSL *.talentchart.hpu.edu.vn (caddy)
SENTRY_DSN=
